import os
import json
import logging
from datetime import datetime
from dotenv import load_dotenv
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import Application, CommandHandler, CallbackQueryHandler, ContextTypes

# Load environment variables
load_dotenv()

BOT_TOKEN = os.getenv("BOT_TOKEN")
ADMIN_ID = int(os.getenv("ADMIN_ID"))

if not BOT_TOKEN:
    raise ValueError("❌ BOT_TOKEN not set in .env file")

# Setup
logging.basicConfig(
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    level=logging.INFO
)
logger = logging.getLogger(__name__)

# Simple JSON database
DB_FILE = "token_updates.json"

def load_db():
    try:
        with open(DB_FILE, "r") as f:
            return json.load(f)
    except FileNotFoundError:
        return {"tokens": {}, "pending_updates": []}

def save_db(data):
    with open(DB_FILE, "w") as f:
        json.dump(data, f, indent=2)

def is_admin(user_id: int) -> bool:
    return user_id == ADMIN_ID

# Command handlers
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    
    if is_admin(user_id):
        await update.message.reply_text(
            "🔧 *Admin Panel*\n\n"
            "Commands:\n"
            "/update `<token_address>` - Queue token update\n"
            "/status - View pending updates\n"
            "/push `<token_address>` - Notify DEX Screener team",
            parse_mode="Markdown"
        )
    else:
        await update.message.reply_text("ℹ️ This bot is for admin use only.")

async def update_token(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Admin: Queue token info update"""
    user_id = update.effective_user.id
    
    if not is_admin(user_id):
        await update.message.reply_text("❌ Unauthorized")
        return
    
    if not context.args:
        await update.message.reply_text("Usage: `/update <token_address>`", parse_mode="Markdown")
        return
    
    token_address = context.args[0]
    
    # Store update request
    db = load_db()
    db["pending_updates"].append({
        "token": token_address,
        "requested_at": str(datetime.now()),
        "status": "pending_dexscreener"
    })
    save_db(db)
    
    # Notify admin (you) about manual action needed
    keyboard = [
        [InlineKeyboardButton("✅ Mark as Submitted", callback_data=f"submitted:{token_address}")],
        [InlineKeyboardButton("🗑 Delete", callback_data=f"delete:{token_address}")]
    ]
    
    await update.message.reply_text(
        f"⏳ *Update Queued*\n\n"
        f"Token: `{token_address}`\n\n"
        f"⚠️ *Manual action required:*\n"
        f"1. Go to [DEX Screener](https://dexscreener.com/solana/{token_address})\n"
        f"2. Click 'Update Token Info'\n"
        f"3. Submit the form\n"
        f"4. Click '✅ Mark as Submitted' here",
        parse_mode="Markdown",
        reply_markup=InlineKeyboardMarkup(keyboard),
        disable_web_page_preview=True
    )

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Handle callback buttons"""
    query = update.callback_query
    await query.answer()
    
    action, token_address = query.data.split(":", 1)
    db = load_db()
    
    if action == "submitted":
        # Update status
        for update_item in db["pending_updates"]:
            if update_item["token"] == token_address:
                update_item["status"] = "submitted"
                update_item["submitted_at"] = str(datetime.now())
                break
        
        save_db(db)
        await query.edit_message_text(
            f"✅ *DEX Screener Update Submitted*\n\n"
            f"Token: `{token_address}`\n"
            f"Status: Awaiting DEX Screener approval (24-48h)",
            parse_mode="Markdown"
        )
        
        # Optional: Notify your user channel
        # await context.bot.send_message(chat_id="@your_channel", text="...")

def main():
    application = Application.builder().token(BOT_TOKEN).build()
    
    application.add_handler(CommandHandler("start", start))
    application.add_handler(CommandHandler("update", update_token))
    application.add_handler(CallbackQueryHandler(button_handler, pattern="^(submitted|delete):"))
    
    logger.info("🤖 Bot started")
    application.run_polling()

if __name__ == "__main__":
    main()
